<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>uk.co.lagoon.wakewatch</string>

    <!-- __PROJECT_DIR__ is replaced by install.sh with the absolute project path -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/run_watch.sh</string>
    </array>

    <!-- Fire every 10 minutes; run_watch.sh applies the schedule policy
         (LAGOON_MODE: build = every firing, production = weekday-hourly +
         weekend-10min 08:00-16:00). -->
    <key>StartInterval</key>
    <integer>600</integer>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/state/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/state/launchd.err.log</string>
</dict>
</plist>
